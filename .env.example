# Website email
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=ada@example.com
SMTP_PASS=replace_with_smtp_password
SMTP_FROM_EMAIL=ada@example.com
SMTP_FROM_NAME=HCJ Piston Rod Website
RFQ_TO_EMAIL=ada@example.com

# Admin database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hcj_admin
DATABASE_SSL=false
ADMIN_SESSION_SECRET=replace_with_at_least_32_random_chars
ADMIN_SETUP_EMAIL=ada@hcjpistonrod.com

# Initial admin creation
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_password
ADMIN_NAME=超级管理员

# Object storage, configure before enabling upload APIs
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# External data sources, optional
GSC_CLIENT_EMAIL=
GSC_PRIVATE_KEY=
GOOGLE_SEARCH_CONSOLE_ENABLED=false
GOOGLE_SEARCH_CONSOLE_SITE_URL=sc-domain:hcjpistonrod.com
GOOGLE_SEARCH_CONSOLE_SITEMAP_URL=https://www.hcjpistonrod.com/sitemap.xml
GOOGLE_SERVICE_ACCOUNT_CREDENTIALS_PATH=
GOOGLE_SERVICE_ACCOUNT_JSON=
ANALYTICS_PROVIDER=
ANALYTICS_API_KEY=
WEBHOOK_SECRET=

# News automation
CRON_SECRET=replace_with_random_cron_secret
NEWS_DAILY_TARGET=4
NEWS_TIMEZONE=Asia/Shanghai
NEWS_MAX_RETRIES=3
NEWS_LOOKBACK_HOURS=72
NEWS_DEDUP_DAYS=7
NEWS_RELEVANCE_THRESHOLD=0.42
NEWS_AUTO_PUBLISH=false
NEWS_ALLOWED_LANGUAGES=en
NEWS_SOURCE_WHITELIST=
NEWS_SOURCE_BLACKLIST=
NEWS_FEED_URLS=
NEWS_ALERT_EMAIL=ada@hcjpistonrod.com
NEWS_API_KEY=
NEWS_API_ENDPOINT=
NEWS_QUERY=hydraulic piston rod chrome plated rod honed tube
AI_PROVIDER_API_KEY=
AI_GATEWAY_API_KEY=
OPENAI_API_KEY=
AI_PROVIDER_BASE_URL=https://api.openai.com/v1
AI_PROVIDER_MODEL=gpt-4.1-mini
